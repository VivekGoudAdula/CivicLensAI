# Application
APP_NAME=CivicLens AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_PROMPT_VERSION=1.0.0
AI_ANALYSIS_ENABLED=true
VISION_ANALYSIS_ENABLED=true
VISION_PROMPT_VERSION=1.0.0
VISION_MAX_IMAGE_DIMENSION=1600
VISION_JPEG_QUALITY=85

# Clustering / Duplicate Detection
CLUSTERING_ENABLED=true
CLUSTERING_PROMPT_VERSION=1.0.0
CLUSTERING_MAX_CANDIDATES=8
CLUSTERING_CANDIDATE_POOL_SIZE=100
CLUSTERING_RADIUS_KM=2.0
CLUSTERING_RECENT_DAYS=90
CLUSTERING_MIN_HEURISTIC_SCORE=0.2
CLUSTERING_DUPLICATE_THRESHOLD=70
CLUSTERING_COMPARISON_CACHE_TTL=3600

# Priority Engine
PRIORITY_ENGINE_ENABLED=true
PRIORITY_PROMPT_VERSION=1.0.0
PRIORITY_CACHE_TTL=3600
PRIORITY_RANKING_LIMIT=500

# Recommendation Engine (Phase 12)
RECOMMENDATION_ENGINE_ENABLED=true
RECOMMENDATION_PROMPT_VERSION=1.0.0
RECOMMENDATION_CACHE_TTL=3600

# Firebase / Firestore
# Option 1: Path to service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Inline JSON (use one of the two options above)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: Firestore emulator for local development
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8085

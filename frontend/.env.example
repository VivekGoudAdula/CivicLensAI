# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Application
VITE_APP_NAME=CivicLens AI
VITE_APP_VERSION=1.0.0

# Google Maps (required for location picker)
# Enable Maps JavaScript API, Places API (New), and Geocoding API in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Firebase / Firestore (MP Dashboard realtime)
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=civiclens-ai-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=civiclens-ai-dev
VITE_FIREBASE_STORAGE_BUCKET=civiclens-ai-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_USE_EMULATOR=true
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_EMULATOR_PORT=8085
